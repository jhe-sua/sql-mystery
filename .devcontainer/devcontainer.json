{
    "name": "PostgreSQL Dev",

    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",

    "features": {
        "ghcr.io/devcontainers/features/postgres:1": {
            "version": "16"
        }
    },

    "forwardPorts": [5432],

    "postCreateCommand": "sudo service postgresql start"
}